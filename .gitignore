.DS_Store
__pycache__/
*.py[cod]
.venv/

# Large workflow inputs and outputs are intentionally not tracked.
data/
reference/
assemblies/
bams/
vcfs/
results/
logs/
work/
tests/tmp/
/figures/

# Common bioinformatics intermediates.
*.bam
*.bai
*.sam
*.cram
*.crai
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.vcf.gz.csi
*.bcf
*.bcf.csi
*.fa
*.fasta
*.fna
*.fai
*.mmi

# Keep the bundled teaching example gtcheck files visible.
!examples/results/
!examples/results/*.gtcheck.tsv

# Keep tiny synthetic VCF fixtures for tests, while ignoring real VCF inputs.
!tests/fixtures/*.vcf
examples/results/example_gtcheck_top3.grin_enriched.xlsx
